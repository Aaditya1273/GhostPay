# GhostPay — Environment Variables
# Copy this file to .env.local and fill in actual values.

# === OAuth Providers ===
# Create a Google OAuth client at https://console.cloud.google.com/apis/credentials
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# === Sui Network ===
NEXT_PUBLIC_SUI_NETWORK=https://fullnode.testnet.sui.io:443
NEXT_PUBLIC_SUI_NETWORK_NAME=testnet

# === Sui Package (deployed Move contract) ===
# Set after running:
#   sui client publish --gas-budget 50000000 .
# Look for "PackageID: 0x..." in the publish output
NEXT_PUBLIC_PACKAGE_ID=

# === Salt Service (for zk proof generation) ===
SALT_SERVICE_URL=http://localhost:5002
ZK_PROVER_URL=https://prover-dev.mystenlabs.com/v1
